# Database
DATABASE_PATH=./sentinel.db

# Supabase API Settings (for Web3 / SSO / Frontend Auth Sync)
SUPABASE_URL=your-supabase-project-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Auth
SECRET_KEY=change-me-to-a-random-32-char-string

# Alchemy (Ethereum RPC — required for scans)
ALCHEMY_API_KEY=your-alchemy-api-key-here

# Etherscan (free tier: 5 calls/sec — required for deep analysis)
ETHERSCAN_API_KEY=your-etherscan-api-key-here

# CoinGecko (optional — for better price data)
COINGECKO_API_KEY=

# Blockchair (optional — apply for free key at blockchair.com)
BLOCKCHAIR_API_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Environment
ENVIRONMENT=development

# ── LLM Providers (cascade: NIM → OpenRouter → Groq → Anthropic) ──
# Get free keys at: build.nvidia.com, openrouter.ai, console.groq.com
NVIDIA_NIM_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
